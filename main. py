import asyncio
import httpx
import time

TOKEN = "8732644562:AAFdPO0dX5WQ-gfO6PSFNRdmXFaDvqTzqe4"
CHAT_ID = "-1003969798912"

async def send_msg(text):
    async with httpx.AsyncClient() as client:
        await client.post(f"https://api.telegram.org/bot{TOKEN}/sendMessage", 
                          json={"chat_id": CHAT_ID, "text": text, "parse_mode": "Markdown"})

async def main():
    await send_msg("🚀 البوت بدأ العمل من GitHub بنجاح!")
    while True:
        now = time.localtime()
        if now.tm_min % 10 == 3 and now.tm_sec == 0:
            await send_msg("🎯 إشارة قنص: [التحليل الثلاثي نشط]")
            await asyncio.sleep(60)
        await asyncio.sleep(1)

if __name__ == "__main__":
